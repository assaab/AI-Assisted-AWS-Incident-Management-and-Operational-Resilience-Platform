# Optional: override the unified API base for production or non-default ports.
# Copy to .env in this folder (apps/console) if you need custom URLs.
# Leave unset during `npm run dev` to use the same-origin /api proxy.
# VITE_API_URL=http://localhost:8080
# Optional: proxy target if the backend is not on localhost:8080 (dev only):
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
